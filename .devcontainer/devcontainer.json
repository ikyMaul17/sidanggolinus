{
    "name": "Laravel App Container",
    "dockerComposeFile": "docker-compose.yaml",
    "service": "devcontainer",
    "forwardPorts": ["frankenphp:80", "phpmyadmin:80"],
    "workspaceFolder": "/var/www/html",
    "customizations": {
        "vscode": {
            "extensions": ["laravel.vscode-laravel", "bmewburn.vscode-intelephense-client", "openai.chatgpt", "codeium.codeium"]
        }
    }
}
